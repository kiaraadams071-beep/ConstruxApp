{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Information about construction workers and admin personnel",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "contractor"] },
        "company": { "type": "string" },
        "contactInfo": { "type": "string" }
      },
      "required": ["uid", "email", "role"]
    },
    "Project": {
      "title": "Construction Project",
      "description": "A construction site being monitored",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "location": { "type": "string" },
        "coordinates": { "type": "object" },
        "status": { "type": "string", "enum": ["planned", "in-progress", "completed"] },
        "weather": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "status"]
    },
    "Attendance": {
      "title": "Daily Attendance",
      "description": "Daily check-in for workforce with selfie and GPS verification",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "projectId": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "selfieUrl": { "type": "string" },
        "latitude": { "type": "number" },
        "longitude": { "type": "number" },
        "verified": { "type": "boolean" }
      },
      "required": ["userId", "projectId", "timestamp", "selfieUrl", "latitude", "longitude"]
    },
    "ProgressReport": {
      "title": "Daily Progress Report",
      "description": "Daily activity tracking, materials usage, and site updates",
      "type": "object",
      "properties": {
        "projectId": { "type": "string" },
        "reporterId": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "description": { "type": "string" },
        "percentageDone": { "type": "number" },
        "materialsUsed": { "type": "array", "items": { "type": "object" } },
        "photoUrls": { "type": "array", "items": { "type": "string" } },
        "weatherConditions": { "type": "string" }
      },
      "required": ["projectId", "reporterId", "timestamp", "percentageDone"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Users of the construction site app"
    },
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Construction projects"
    },
    "/attendance/{attendanceId}": {
      "schema": "Attendance",
      "description": "Attendance log entries"
    },
    "/projects/{projectId}/reports/{reportId}": {
      "schema": "ProgressReport",
      "description": "Detailed daily progress reports for a project"
    }
  }
}
